{
  "name": "ai-workflow-builder-template",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "A template for building your own AI-driven workflow automation platform",
  "scripts": {
    "dev": "pnpm discover-plugins && next dev",
    "build": "tsx scripts/migrate-prod.ts && pnpm discover-plugins && next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "check": "pnpm exec ultracite check",
    "fix": "pnpm exec ultracite fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "discover-plugins": "tsx scripts/discover-plugins.ts",
    "create-plugin": "tsx scripts/create-plugin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "pnpm discover-plugins"
  },
  "dependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@linear/sdk": "^63.2.0",
    "@mendable/firecrawl-js": "^4.6.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@slack/web-api": "^7.12.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/og": "^0.8.5",
    "@vercel/sdk": "^1.17.1",
    "@vercel/speed-insights": "^1.2.0",
    "@xyflow/react": "^12.9.2",
    "ai": "^5.0.102",
    "better-auth": "^1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.1.3",
    "jotai": "^2.15.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.552.0",
    "motion": "^12.23.24",
    "nanoid": "^5.1.6",
    "next": "^16.2.3",
    "next-intl": "3.26.5",
    "next-themes": "^0.4.6",
    "openai": "^6.8.1",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-resizable-panels": "^3.0.6",
    "resend": "^6.4.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "workflow": "4.0.1-beta.17",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@inquirer/prompts": "^8.0.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.6",
    "knip": "^5.70.1",
    "prettier": "^3.7.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "ultracite": "6.3.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "axios@<1.15.0": "1.15.0",
      "undici@>=6.0.0 <6.24.0": "6.24.0",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "devalue@>=5.1.0 <5.6.2": "5.6.2",
      "defu@<=6.1.4": "6.1.5",
      "fast-xml-parser@>=5.0.0 <5.5.6": "5.5.6",
      "glob@>=11.0.0 <11.1.0": "11.1.0",
      "kysely@<=0.28.13": "0.28.14"
    }
  }
}
